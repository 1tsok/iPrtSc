<Window x:Class="iPrtSc.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False"
        Topmost="True" Background="Black" Cursor="Arrow"
        WindowStartupLocation="Manual" SnapsToDevicePixels="True" UseLayoutRounding="True"
        Loaded="OnLoaded" PreviewKeyDown="OnKeyDown" PreviewMouseWheel="OnWheel">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#FF0A84FF"/>

        <!-- Action buttons (Segoe Fluent Icons) -->
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Line-icon path (single consistent stroke style, drawn on a 24x24 grid) -->
        <Style x:Key="Icon" TargetType="Path">
            <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ButtonBase}}"/>
            <Setter Property="StrokeThickness" Value="1.5"/>
            <Setter Property="StrokeStartLineCap" Value="Round"/>
            <Setter Property="StrokeEndLineCap" Value="Round"/>
            <Setter Property="StrokeLineJoin" Value="Round"/>
            <Setter Property="Fill" Value="Transparent"/>
        </Style>

        <!-- Filled-dot icon (e.g. grip), shares the button foreground -->
        <Style x:Key="IconFill" TargetType="Path">
            <Setter Property="Fill" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ButtonBase}}"/>
        </Style>

        <!-- Tool toggles -->
        <Style x:Key="ToolToggle" TargetType="ToggleButton">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource Accent}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Right-click context menu -->
        <Style x:Key="CtxMenu" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="#F0202124" BorderBrush="#26FFFFFF" BorderThickness="1"
                                CornerRadius="8" Padding="4" MinWidth="200">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.55" Color="Black"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CtxItem" TargetType="MenuItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Foreground" Value="#FFF1F1F1"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable, Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                                Margin="0,1" Padding="10,7,12,7">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{TemplateBinding Header}" VerticalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock Grid.Column="1" Text="{TemplateBinding InputGestureText}"
                                           Foreground="#FF8E8E93" VerticalAlignment="Center"
                                           Margin="24,0,0,0" FontSize="12"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#FF4F4F52"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CtxSep" TargetType="Separator">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="#26FFFFFF" Margin="8,3"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Horizontal separator (inside vertical panel) -->
        <Style x:Key="HSep" TargetType="Border">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="3,3"/>
            <Setter Property="Background" Value="#26FFFFFF"/>
        </Style>

        <Style x:Key="Panel" TargetType="Border">
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Background" Value="#F0202124"/>
            <Setter Property="BorderBrush" Value="#26FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="3" Opacity="0.55" Color="Black"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="Root">
        <!-- Frozen screenshot -->
        <Image x:Name="BaseImage" Stretch="Fill"/>

        <!-- Spotlight dimming -->
        <Canvas x:Name="DimCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="DimTop" Fill="#9B000000"/>
            <Rectangle x:Name="DimLeft" Fill="#9B000000"/>
            <Rectangle x:Name="DimRight" Fill="#9B000000"/>
            <Rectangle x:Name="DimBottom" Fill="#9B000000"/>
        </Canvas>

        <!-- Annotations (clipped to selection); hit-test enabled for the Move tool -->
        <Canvas x:Name="AnnotCanvas" IsHitTestVisible="True"/>

        <!-- Mouse surface. Cursor is driven from code (UpdateCursor): the special cursor
             (crosshair / brush / text / move) shows only inside the selected region; the
             dimmed backdrop and the chrome keep a plain arrow. -->
        <Border x:Name="Hit" Background="Transparent" Cursor="Arrow"
                MouseLeftButtonDown="OnMouseDown" MouseMove="OnMouseMove" MouseLeftButtonUp="OnMouseUp"
                MouseRightButtonUp="OnRightClick"/>

        <!-- Selection border + size label -->
        <Canvas x:Name="SelCanvas" IsHitTestVisible="False">
            <Rectangle x:Name="SelBorder" Stroke="#FF0A84FF" StrokeThickness="1.5" Visibility="Collapsed"/>
            <Border x:Name="SizeLabel" Visibility="Collapsed" Background="#CC000000" CornerRadius="4" Padding="6,2">
                <TextBlock x:Name="SizeText" Foreground="White" FontSize="12" FontFamily="Segoe UI"/>
            </Border>
        </Canvas>

        <!-- Resize handles (created in code) -->
        <Canvas x:Name="HandleCanvas" IsHitTestVisible="True"/>

        <!-- Hint (positioned in code, centered on the monitor under the cursor) -->
        <Canvas x:Name="HintCanvas" IsHitTestVisible="False">
            <Border x:Name="HintPill"
                    Background="#CC202124" BorderBrush="#26FFFFFF" BorderThickness="1" CornerRadius="10" Padding="16,9">
                <TextBlock Foreground="#FFEDEDED" FontSize="13" FontFamily="Segoe UI"
                           Text="Drag to select    •    Enter to copy    •    Esc to cancel"/>
            </Border>
        </Canvas>

        <!-- Panels -->
        <Canvas x:Name="UiCanvas">
            <!-- Vertical tools panel (right of selection) -->
            <Border x:Name="ToolPanel" Style="{StaticResource Panel}" Visibility="Collapsed">
                <StackPanel Orientation="Vertical">
                    <ToggleButton x:Name="ToolSelect" Style="{StaticResource ToolToggle}" Tag="Select" ToolTip="Select area" Click="OnToolClick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M6 2v14a2 2 0 0 0 2 2h14 M18 22V8a2 2 0 0 0-2-2H2"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolMove" Style="{StaticResource ToolToggle}" Tag="Move" ToolTip="Move objects" Click="OnToolClick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M5 9 2 12 5 15 M9 5 12 2 15 5 M15 19 12 22 9 19 M19 9 22 12 19 15 M2 12H22 M12 2v20"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolPen" Style="{StaticResource ToolToggle}" Tag="Pen" ToolTip="Pen" Click="OnToolClick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z M15 5l4 4"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolMarker" Style="{StaticResource ToolToggle}" Tag="Marker" ToolTip="Highlighter" Click="OnToolClick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M9 11 3 17v3h9l3-3 M22 12l-4.6 4.6a2 2 0 0 1-2.8 0l-5.2-5.2a2 2 0 0 1 0-2.8L14 4"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <!-- Shapes group: short click reuses the last-picked shape (1 click); press-and-hold
                         or right-click opens the picker. The chevron under the icon hints at the picker
                         and shares the button foreground, so it stays clean on the accent (active) state. -->
                    <ToggleButton x:Name="ShapesGroup" Style="{StaticResource ToolToggle}"
                                  ToolTip="Shapes — click: last shape · hold / right-click: choose"
                                  PreviewMouseLeftButtonDown="OnShapesDown"
                                  PreviewMouseLeftButtonUp="OnShapesUp"
                                  PreviewMouseRightButtonUp="OnShapesRightUp">
                        <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                            <Viewbox Width="16" Height="16" HorizontalAlignment="Center"><Canvas Width="24" Height="24">
                                <Path x:Name="ShapesIcon" Style="{StaticResource Icon}" Data="M13 3H21V11 M21 3 3 21"/>
                            </Canvas></Viewbox>
                            <Path Margin="0,1.5,0,0" HorizontalAlignment="Center" Data="M0 0 L3 2.5 L6 0"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ButtonBase}}"
                                  StrokeThickness="1.3" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                        </StackPanel>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolText" Style="{StaticResource ToolToggle}" Tag="Text" ToolTip="Text" Click="OnToolClick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M4 7V4h16v3 M9 20h6 M12 4v16"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolCounter" Style="{StaticResource ToolToggle}" Tag="Counter" ToolTip="Numbered step" Click="OnToolClick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z M11 9.5 12.5 8.5V16 M10.5 16h4"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolBlur" Style="{StaticResource ToolToggle}" Tag="Blur" ToolTip="Pixelate area" Click="OnToolClick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource IconFill}" Data="M3.5 5a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0 M10.5 5a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0 M17.5 5a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0 M3.5 12a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0 M10.5 12a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0 M17.5 12a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0 M3.5 19a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0 M10.5 19a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0 M17.5 19a1.5 1.5 0 1 0 3 0 1.5 1.5 0 1 0-3 0"/>
                        </Canvas></Viewbox>
                    </ToggleButton>

                    <Border Style="{StaticResource HSep}"/>

                    <Button x:Name="ColorButton" Style="{StaticResource ToolBtn}" Margin="1" ToolTip="Color" Click="OnColorButtonClick">
                        <!-- Hairline ring in the app's chrome tone (not stark white); still defines the
                             edge so dark colours stay visible on the dark panel. -->
                        <Ellipse x:Name="ColorDot" Width="15" Height="15" Fill="#FFE81123"
                                 Stroke="#40FFFFFF" StrokeThickness="1"/>
                    </Button>

                    <Border Style="{StaticResource HSep}"/>

                    <Button x:Name="UndoBtn" Style="{StaticResource ToolBtn}" Margin="1" ToolTip="Undo (Ctrl+Z)" Click="OnUndo">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M9 14 4 9l5-5 M4 9h10.5a5.5 5.5 0 0 1 5.5 5.5 5.5 5.5 0 0 1-5.5 5.5H11"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button x:Name="RedoBtn" Style="{StaticResource ToolBtn}" Margin="1" ToolTip="Redo (Ctrl+Y)" Click="OnRedo">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M15 14 20 9l-5-5 M20 9H9.5A5.5 5.5 0 0 0 4 14.5 5.5 5.5 0 0 0 9.5 20H13"/>
                        </Canvas></Viewbox>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Color flyout (opens from the color button) -->
            <Border x:Name="ColorFlyout" Style="{StaticResource Panel}" Visibility="Collapsed">
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Colors" Foreground="#FFF1F1F1" FontFamily="Segoe UI Variable, Segoe UI"
                               FontSize="13" Margin="4,1,0,6"/>
                    <UniformGrid x:Name="ColorRow" Columns="6"/>
                </StackPanel>
            </Border>

            <!-- Shapes flyout (opens from the shapes-group caret) -->
            <Border x:Name="ShapesFlyout" Style="{StaticResource Panel}" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <ToggleButton x:Name="ToolArrow" Style="{StaticResource ToolToggle}" Tag="Arrow" ToolTip="Arrow" Click="OnShapePick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M13 3H21V11 M21 3 3 21"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolLine" Style="{StaticResource ToolToggle}" Tag="Line" ToolTip="Line" Click="OnShapePick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M21 3 3 21"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolRect" Style="{StaticResource ToolToggle}" Tag="Rect" ToolTip="Rectangle (Shift = square)" Click="OnShapePick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M5 3h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                    <ToggleButton x:Name="ToolEllipse" Style="{StaticResource ToolToggle}" Tag="Ellipse" ToolTip="Ellipse (Shift = circle)" Click="OnShapePick">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M12 3a9 9 0 1 0 0 18 9 9 0 0 0 0-18z"/>
                        </Canvas></Viewbox>
                    </ToggleButton>
                </StackPanel>
            </Border>

            <!-- Save / actions panel (bottom-right of selection) -->
            <Border x:Name="ActionPanel" Style="{StaticResource Panel}" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal">
                    <!-- Buy me a coffee — amber tint + a one-button gap so it never blends with the capture actions -->
                    <Button Style="{StaticResource ToolBtn}" Foreground="#FFFFB84D" ToolTip="Buy me a coffee ☕" Click="OnBuyCoffee">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M6 2v2 M10 2v2 M14 2v2 M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a4 4 0 0 1 0 8h-1"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Border Width="26"/>
                    <Button Style="{StaticResource ToolBtn}" ToolTip="Copy (Enter)" Click="OnCopy">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M8 8h10a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2V10a2 2 0 0 1 2-2z M4 16a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Button Style="{StaticResource ToolBtn}" ToolTip="Save (Ctrl+S)" Click="OnSave">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M15.2 3a2 2 0 0 1 1.4.6l3.8 3.8a2 2 0 0 1 .6 1.4V19a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z M17 21v-7a1 1 0 0 0-1-1H8a1 1 0 0 0-1 1v7 M7 3v4a1 1 0 0 0 1 1h7"/>
                        </Canvas></Viewbox>
                    </Button>
                    <Border Width="1" Margin="3,4" Background="#26FFFFFF"/>
                    <Button Style="{StaticResource ToolBtn}" ToolTip="Cancel (Esc)" Click="OnCancel">
                        <Viewbox Width="19" Height="19"><Canvas Width="24" Height="24">
                            <Path Style="{StaticResource Icon}" Data="M18 6 6 18 M6 6 18 18"/>
                        </Canvas></Viewbox>
                    </Button>
                </StackPanel>
            </Border>
        </Canvas>

        <!-- Brush-size cursor -->
        <Canvas x:Name="CursorLayer" IsHitTestVisible="False">
            <Ellipse x:Name="BrushCursor" Visibility="Collapsed" IsHitTestVisible="False"
                     Stroke="#FFE81123" StrokeThickness="1.5">
                <Ellipse.Effect>
                    <DropShadowEffect BlurRadius="3" ShadowDepth="0" Color="Black" Opacity="0.7"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>
    </Grid>
</Window>
