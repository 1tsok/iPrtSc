<Window x:Class="iPrtSc.HistoryFlyout"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True"
        SizeToContent="WidthAndHeight" WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable, Segoe UI"
        Deactivated="OnDeactivated" PreviewKeyDown="OnKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="Fg" Color="#FFF1F1F1"/>
        <SolidColorBrush x:Key="Fg2" Color="#FF85858B"/>
        <!-- Accent brushes are re-tinted at runtime from the user's chosen accent. -->
        <SolidColorBrush x:Key="Accent" Color="#FF0A84FF"/>
        <SolidColorBrush x:Key="AccentSoft" Color="#330A84FF"/>

        <!-- Pin toggle: when checked, the flyout stays open instead of closing on focus loss. -->
        <Style x:Key="PinBtn" TargetType="ToggleButton">
            <Setter Property="Width" Value="26"/>
            <Setter Property="Height" Value="26"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="6">
                            <Viewbox Width="15" Height="15">
                                <Canvas Width="24" Height="24">
                                    <Path x:Name="icon" Stroke="{StaticResource Fg2}" StrokeThickness="1.7"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                          Fill="Transparent"
                                          Data="M12 17v5 M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#1FFFFFFF"/>
                                <Setter TargetName="icon" Property="Stroke" Value="{StaticResource Fg}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{DynamicResource AccentSoft}"/>
                                <Setter TargetName="icon" Property="Stroke" Value="{DynamicResource Accent}"/>
                                <Setter TargetName="icon" Property="Fill" Value="{DynamicResource AccentSoft}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- A single thumbnail tile -->
        <Style x:Key="ThumbTile" TargetType="Border">
            <Setter Property="Width" Value="112"/>
            <Setter Property="Height" Value="74"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Background" Value="#FF161618"/>
            <Setter Property="BorderBrush" Value="#22FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Footer action button (matches the flyout's subtle dark style) -->
        <Style x:Key="FolderBtn" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource Fg}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="#16FFFFFF" CornerRadius="7" Padding="8,7"
                                BorderBrush="#22FFFFFF" BorderThickness="1">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Viewbox Width="14" Height="14" Margin="0,0,7,0" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Stroke="{StaticResource Fg}" StrokeThickness="1.6"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Fill="Transparent" Data="M3 7a2 2 0 0 1 2-2h3.9a2 2 0 0 1 1.4.6L12 7h7a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                                    </Canvas>
                                </Viewbox>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#2BFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer margin leaves room for the drop shadow (window is transparent). -->
    <Grid Margin="16">
        <Border Background="#F0202124" BorderBrush="#26FFFFFF" BorderThickness="1"
                CornerRadius="10" Padding="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="4" Opacity="0.55" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <!-- Header doubles as a drag handle so the flyout can be repositioned. -->
                <Border Background="Transparent" Cursor="SizeAll" Margin="0,0,0,8"
                        MouseLeftButtonDown="OnDragHandle">
                    <Grid Margin="6,4,4,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Recent screenshots" Foreground="{StaticResource Fg}"
                                   FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"
                                   Margin="0,0,14,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ToggleButton x:Name="PinToggle" Style="{StaticResource PinBtn}"
                                          ToolTip="Keep this window open"/>
                            <!-- Subtle grip hinting the header is draggable -->
                            <Path Margin="8,0,2,0" VerticalAlignment="Center" Fill="{StaticResource Fg2}"
                                  Data="M0 0h2v2H0z M4 0h2v2H4z M0 4h2v2H0z M4 4h2v2H4z M0 8h2v2H0z M4 8h2v2H4z"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <WrapPanel x:Name="ThumbHost" Width="366"/>
                <TextBlock x:Name="EmptyLabel" Text="No screenshots yet" Foreground="{StaticResource Fg2}"
                           FontSize="13" Margin="6,8,6,12" Visibility="Collapsed"/>
                <TextBlock x:Name="ClickHint" Foreground="{StaticResource Fg2}" FontSize="11" Margin="6,6,6,8"
                           Text="Left-click: copy  ·  Right-click: open"/>
                <Button Style="{StaticResource FolderBtn}" Content="Open history folder"
                        Click="OnOpenFolder" Margin="5,0,5,4"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
