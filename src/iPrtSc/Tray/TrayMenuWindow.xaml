<Window x:Class="iPrtSc.TrayMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="False" ResizeMode="NoResize" Topmost="True"
        SizeToContent="WidthAndHeight" WindowStartupLocation="Manual"
        FontFamily="Segoe UI Variable, Segoe UI"
        Deactivated="OnDeactivated" PreviewKeyDown="OnKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="FgItem" Color="#FFF1F1F1"/>
        <SolidColorBrush x:Key="FgShortcut" Color="#FF85858B"/>
        <SolidColorBrush x:Key="Sep" Color="#26FFFFFF"/>

        <Style x:Key="MenuItemStyle" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="12,0,14,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer margin leaves room for the drop shadow (window is transparent). -->
    <Grid Margin="16">
        <Border Background="#F0202124" BorderBrush="#26FFFFFF" BorderThickness="1"
                CornerRadius="10" Padding="4" MinWidth="208">
            <Border.Effect>
                <DropShadowEffect BlurRadius="22" ShadowDepth="4" Opacity="0.55" Color="Black"/>
            </Border.Effect>
            <StackPanel x:Name="ItemsHost"/>
        </Border>
    </Grid>
</Window>
