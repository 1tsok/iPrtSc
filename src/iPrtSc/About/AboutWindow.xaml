<Window x:Class="iPrtSc.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About iPrtSc"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        ResizeMode="NoResize" ShowInTaskbar="False" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI"
        MouseLeftButtonDown="OnDragMove" PreviewKeyDown="OnKeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="Accent" Color="#FF0A84FF"/>
        <SolidColorBrush x:Key="Fg" Color="#FFEDEDED"/>
        <SolidColorBrush x:Key="Fg2" Color="#FFA8A8AD"/>

        <Style x:Key="CloseBtn" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="7">
                            <Viewbox Width="19" Height="19" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#FFC8C8CC" StrokeThickness="1.8"
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M18 6 6 18 M6 6 18 18"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Border Background="#FF1E1E20" BorderBrush="#26FFFFFF" BorderThickness="1"
                CornerRadius="14" Padding="24,18,24,24" Width="360">
            <Border.Effect>
                <DropShadowEffect BlurRadius="26" ShadowDepth="5" Opacity="0.55" Color="Black"/>
            </Border.Effect>

            <Grid>
                <StackPanel>
                    <!-- Logo: same crop-mark brackets as the app icon -->
                    <Viewbox Width="56" Height="56" HorizontalAlignment="Center" Margin="0,10,0,14">
                        <Canvas Width="24" Height="24">
                            <Path Stroke="{StaticResource Accent}" StrokeThickness="2.1"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                  Fill="Transparent"
                                  Data="M9 4 5 4 5 8 M15 4 19 4 19 8 M9 20 5 20 5 16 M15 20 19 20 19 16"/>
                        </Canvas>
                    </Viewbox>

                    <TextBlock Text="iPrtSc" Foreground="{StaticResource Fg}" FontSize="24" FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="VersionText" Foreground="{StaticResource Fg2}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="A fast, lightweight screenshot tool." Foreground="{StaticResource Fg2}"
                               FontSize="13" HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,14,0,0" TextWrapping="Wrap"/>

                    <TextBlock Foreground="{StaticResource Fg2}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,12,0,0">
                        <Run Text="Contact: "/><Hyperlink NavigateUri="mailto:code.ihor.k@gmail.com"
                                  Foreground="{StaticResource Accent}" TextDecorations="None"
                                  RequestNavigate="OnNavigate">code.ihor.k@gmail.com</Hyperlink>
                    </TextBlock>

                    <TextBlock x:Name="CopyrightText" Foreground="#FF6E6E73" FontSize="12"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                </StackPanel>

                <!-- Close button: overlaid top-right with equal 9px gaps from both edges -->
                <Button Style="{StaticResource CloseBtn}" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,-9,-15,0" Click="OnClose"/>
            </Grid>
        </Border>
    </Grid>
</Window>
